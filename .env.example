# Polymarket API Configuration
# Copy this file to .env and fill in your values

# Your Ethereum private key (0x prefixed hex string)
# NEVER commit the actual private key - use .env only during local development
PRIVATE_KEY=

# Your wallet address (where you hold pUSD and POL)
WALLET_ADDRESS=

# RPC endpoint for Polygon mainnet (optional - uses default if not provided)
RPC_URL=https://polygon-rpc.com

# Polymarket API endpoints
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com

# Strategy Configuration
STRATEGY_NAME=demo_strategy
DEMO_BALANCE=1000
TRADE_SIZE=10
PRICE_TARGET=0.50

# Realism Settings
# ENABLE_REALISTIC_SLIPPAGE: true/false
#   false = Simplified simulation (ignore bid-ask slippage)
#   true = Realistic simulation (includes slippage from spreads)
# Note: Fees & Gas costs are ALWAYS included (real Polymarket & Polygon costs)
ENABLE_REALISTIC_SLIPPAGE=false

# Application Settings
LOG_LEVEL=info
NODE_ENV=development

# Optional: For storing API credentials after first auth
# These are generated automatically, no need to set manually
# API_KEY=
# API_SECRET=
# API_PASSPHRASE=

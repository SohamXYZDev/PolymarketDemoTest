{
  "name": "polymarket-demo-test",
  "version": "1.0.0",
  "description": "Test trading strategies on live Polymarket with demo balance. Production-ready implementation with proper env config.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --loader tsx/esm src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "polymarket",
    "trading",
    "prediction-market",
    "strategy",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client-v2": "latest",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "viem": "^1.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
